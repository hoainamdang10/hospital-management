# V2 Services Environment Configuration
# Shared configuration for all V2 microservices

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=your_super_secure_jwt_secret_here_minimum_32_characters_for_production_use

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =============================================================================
# REDIS CONFIGURATION (Auto-configured by docker-compose)
# =============================================================================
REDIS_URL=redis://redis-v2:6379

# =============================================================================
# RABBITMQ CONFIGURATION (Auto-configured by docker-compose)
# =============================================================================
RABBITMQ_URL=amqp://admin:admin@rabbitmq-v2:5672

# =============================================================================
# SCHEDULER SERVICE CONFIGURATION
# =============================================================================
# Scheduler Service URL for inter-service communication
# Development: http://localhost:3030
# Docker: http://scheduler-service:3030
SCHEDULER_SERVICE_URL=http://scheduler-service:3030
SCHEDULER_API_KEY=  # Optional: JWT token for service-to-service authentication

# =============================================================================
# BILLING SERVICE - PAYOS CONFIGURATION
# =============================================================================
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# =============================================================================
# NOTIFICATIONS SERVICE CONFIGURATION
# =============================================================================
EMAIL_SERVICE_API_KEY=your_email_service_api_key
SMS_SERVICE_API_KEY=your_sms_service_api_key

# =============================================================================
# IDENTITY SERVICE - EMAIL VERIFICATION CONFIGURATION
# =============================================================================
# Resend API Key for sending verification emails
# Get your API key from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000 emails/month
RESEND_API_KEY=re_your_resend_api_key_here

# Frontend URL for email verification links
# This URL will be used to construct verification links sent in emails
# Example: http://localhost:3000/auth/verify-email?token=xxx
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
NODE_ENV=development
