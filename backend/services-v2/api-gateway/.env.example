# Server Configuration
PORT=3101
NODE_ENV=development

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED for JWT Validation)
# =============================================================================
# Supabase Project URL (from Supabase Dashboard -> Settings -> API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (from Supabase Dashboard -> Settings -> API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase JWT Secret (from Supabase Dashboard -> Settings -> API -> JWT Settings)
# ⚠️ CRITICAL: This MUST match the JWT secret used by Supabase Auth
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT_SECRET should match SUPABASE_JWT_SECRET for consistency
# If both are set and differ, SUPABASE_JWT_SECRET takes precedence
JWT_SECRET=${SUPABASE_JWT_SECRET}

# Optional: JWT Issuer and Audience (for additional validation)
JWT_ISSUER=hospital-management-system
JWT_AUDIENCE=api-gateway

# Service URLs (Internal Docker Network)
IDENTITY_SERVICE_URL=http://identity-service:3001
PATIENT_REGISTRY_SERVICE_URL=http://patient-registry-service:3003
PROVIDER_STAFF_SERVICE_URL=http://provider-staff-service:3002
SCHEDULING_SERVICE_URL=http://scheduling-service:3004
CLINICAL_EMR_SERVICE_URL=http://clinical-emr-service:3007
BILLING_SERVICE_URL=http://billing-service:3009
NOTIFICATIONS_SERVICE_URL=http://notifications-service:3011

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =============================================================================
# REDIS CONFIGURATION (for Distributed Rate Limiting)
# =============================================================================
# Redis URL (Docker internal network)
REDIS_URL=redis://redis-v2:6379

# Redis Password (optional)
REDIS_PASSWORD=

# Redis Database for Rate Limiting (separate from cache)
REDIS_RATE_LIMIT_DB=1

# =============================================================================
# RATE LIMITING CONFIGURATION (Redis-based Distributed)
# =============================================================================
# Global rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=900000          # 15 minutes
RATE_LIMIT_MAX_REQUESTS=1000         # Max requests per window

# Per-user rate limiting (authenticated users)
RATE_LIMIT_USER_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_USER_MAX_REQUESTS=500     # Max requests per user per window

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Identity Service Client Configuration
# Number of retries for failed requests
IDENTITY_SERVICE_RETRIES=3

# =============================================================================
# TIMEOUT CONFIGURATION (Optional - defaults are optimized)
# =============================================================================
# Health check timeout (milliseconds)
TIMEOUT_HEALTH_CHECK=3000

# Service call timeouts
TIMEOUT_SERVICE_FAST=5000      # Permission checks, simple queries
TIMEOUT_SERVICE_NORMAL=10000   # CRUD operations
TIMEOUT_SERVICE_SLOW=30000     # Complex queries, reports

# Proxy timeouts
TIMEOUT_PROXY_REQUEST=15000    # Client -> Gateway
TIMEOUT_PROXY_UPSTREAM=12000   # Gateway -> Service (must be < request)

# Circuit breaker timeouts
TIMEOUT_CIRCUIT_BREAKER_RESET=30000
TIMEOUT_CIRCUIT_BREAKER_HALF_OPEN=10000

# Database timeouts
TIMEOUT_DATABASE_QUERY=10000
TIMEOUT_DATABASE_TRANSACTION=30000

# =============================================================================
# CIRCUIT BREAKER CONFIGURATION
# =============================================================================
# Number of failures before opening circuit
CIRCUIT_BREAKER_THRESHOLD=5

# Monitoring period for failure tracking (milliseconds)
CIRCUIT_BREAKER_MONITORING_PERIOD=60000

# Number of successful calls in HALF_OPEN state before closing circuit
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# =============================================================================
# FALLBACK CACHE CONFIGURATION
# =============================================================================
# Enable fallback cache for circuit breaker
ENABLE_FALLBACK_CACHE=true

# Cache TTL for fallback responses (milliseconds)
CACHE_FALLBACK_TTL=300000

# Maximum cache size (number of entries)
CACHE_MAX_SIZE=1000

# =============================================================================
# RETRY POLICY CONFIGURATION
# =============================================================================
# Maximum number of retry attempts
RETRY_MAX_ATTEMPTS=3

# Initial delay before first retry (milliseconds)
RETRY_INITIAL_DELAY_MS=100

# Maximum delay between retries (milliseconds)
RETRY_MAX_DELAY_MS=5000

# Backoff multiplier for exponential backoff
RETRY_BACKOFF_MULTIPLIER=2

# =============================================================================
# REQUEST/RESPONSE SIZE LIMITS
# =============================================================================
# Default request size limit (bytes)
REQUEST_SIZE_LIMIT=1048576  # 1MB

# Enable response size monitoring
ENABLE_RESPONSE_SIZE_MONITORING=true

# Maximum response size before warning (bytes)
MAX_RESPONSE_SIZE=10485760  # 10MB

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
# Maximum number of health check retries
HEALTH_CHECK_MAX_RETRIES=2

# Initial delay before first retry (milliseconds)
HEALTH_CHECK_RETRY_DELAY_MS=100

