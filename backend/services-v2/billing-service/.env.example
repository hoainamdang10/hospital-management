# Billing Service - Environment Configuration Template
# Copy this file to .env and fill in your values
# For multi-env setup: use .env.local (dev) or .env.docker (Docker)

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3009

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_SCHEMA=billing_schema

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=your_jwt_secret

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Local: redis://localhost:6379
# Docker: redis://redis-v2:6379
REDIS_URL=redis://localhost:6379

# =============================================================================
# RABBITMQ CONFIGURATION
# =============================================================================
# Local: amqp://admin:admin@localhost:5672
# Docker: amqp://admin:admin@rabbitmq-v2:5672
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# =============================================================================
# INTER-SERVICE COMMUNICATION
# =============================================================================
# Local: http://localhost:PORT
# Docker: http://service-name:PORT
IDENTITY_SERVICE_URL=http://localhost:3001
PATIENT_SERVICE_URL=http://localhost:3003
CLINICAL_SERVICE_URL=http://localhost:3007

# =============================================================================
# PAYOS PAYMENT GATEWAY CONFIGURATION
# Get credentials from: https://payos.vn/
# =============================================================================
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:3000/patient/billing/success
PAYOS_CANCEL_URL=http://localhost:3000/patient/billing/cancel

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
