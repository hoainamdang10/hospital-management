# Provider/Staff Service - Environment Configuration
# V2 Clean Architecture + DDD Implementation
# Copy this file to .env and fill in your actual values

# =====================================================
# SERVER CONFIGURATION
# =====================================================
NODE_ENV=development
PORT=3002
SERVICE_NAME=provider-staff-service
SERVICE_VERSION=2.0.0

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Database Schema
DATABASE_SCHEMA=provider_schema

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
JWT_SECRET=your_jwt_secret_for_services
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =====================================================
# MESSAGING & CACHING
# =====================================================
REDIS_URL=redis://redis-v2:6379
RABBITMQ_URL=amqp://admin:admin@rabbitmq-v2:5672

# RabbitMQ Event Publishing Configuration
RABBITMQ_EXCHANGE=hospital.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_DURABLE=true
RABBITMQ_AUTO_DELETE=false
RABBITMQ_ENABLE_RETRY=true
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAY_MS=1000
RABBITMQ_ENABLE_LOGGING=true

# =====================================================
# LOGGING CONFIGURATION
# =====================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =====================================================
# CIRCUIT BREAKER CONFIGURATION
# =====================================================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30000

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ENABLED=true
CORS_CREDENTIALS=true

# =====================================================
# HEALTHCARE COMPLIANCE
# =====================================================
ENABLE_HIPAA_COMPLIANCE=true
ENABLE_VIETNAMESE_HEALTHCARE_COMPLIANCE=true
ENABLE_AUDIT_LOGGING=true

# =====================================================
# MONITORING & OBSERVABILITY
# =====================================================
ENABLE_METRICS=true
ENABLE_HEALTH_CHECKS=true
ENABLE_PERFORMANCE_MONITORING=true

# =====================================================
# DEVELOPMENT CONFIGURATION
# =====================================================
DEBUG=false
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=false

