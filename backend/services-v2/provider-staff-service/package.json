{
  "name": "provider-staff-service",
  "version": "1.0.0",
  "description": "Provider/Staff Service - Hospital Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/main.ts",
    "dev:legacy": "nodemon src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "start:legacy": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --config jest.integration.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:unit": "jest --coverage --testPathIgnorePatterns=integration",
    "test:coverage:integration": "jest --config jest.integration.config.js --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "@supabase/supabase-js": "^2.38.0",
    "amqplib": "^0.10.3",
    "uuid": "^9.0.0",
    "joi": "^17.9.2",
    "winston": "^3.10.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.4",
    "@types/uuid": "^9.0.2",
    "@types/compression": "^1.7.2",
    "@types/amqplib": "^0.10.1",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "@types/jest": "^29.5.3",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "jest-junit": "^16.0.0",
    "tsc-alias": "^1.8.8",
    "eslint": "^8.46.0",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1"
  },
  "keywords": [
    "hospital-management",
    "healthcare",
    "microservice",
    "clean-architecture",
    "ddd",
    "cqrs",
    "event-driven"
  ]
}