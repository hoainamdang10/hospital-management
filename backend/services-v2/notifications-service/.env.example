# =============================================================================
# NOTIFICATIONS SERVICE - ENVIRONMENT CONFIGURATION
# =============================================================================

# =============================================================================
# 1. SUPABASE CONFIGURATION (Required ✅)
# =============================================================================
SUPABASE_URL=https://ciasxktujslgsdgylimv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# 2. SERVICE CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3031
SERVICE_NAME=notifications-service

# =============================================================================
# 3. SENDGRID CONFIGURATION (Email) 📧
# =============================================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@hospital.vn
SENDGRID_FROM_NAME=Bệnh viện Đa khoa
SENDGRID_ENABLED=true

# =============================================================================
# 4. TWILIO CONFIGURATION (SMS) 📱
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+84xxxxxxxxx
TWILIO_ENABLED=true

# =============================================================================
# 5. FIREBASE CONFIGURATION (Push Notifications) 🔔
# =============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@project.iam.gserviceaccount.com
FIREBASE_ENABLED=false

# =============================================================================
# 6. RABBITMQ CONFIGURATION (Event Bus)
# =============================================================================
RABBITMQ_URL=amqp://admin:admin@localhost:5673
RABBITMQ_EXCHANGE=hospital.events

# =============================================================================
# 7. REDIS CONFIGURATION (Cache)
# =============================================================================
REDIS_URL=redis://localhost:6380
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# 8. NOTIFICATION QUEUE CONFIGURATION
# =============================================================================
NOTIFICATION_QUEUE_POLL_INTERVAL_MS=5000
NOTIFICATION_QUEUE_BATCH_SIZE=20
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=60000

# =============================================================================
# 9. LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
