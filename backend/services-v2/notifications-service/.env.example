# =============================================================================
# NOTIFICATIONS SERVICE - ENVIRONMENT CONFIGURATION
# MVP Version - Appointment Booking + Payment Flow
# =============================================================================

# =============================================================================
# 1. SUPABASE CONFIGURATION (Required ✅)
# =============================================================================
SUPABASE_URL=https://ciasxktujslgsdgylimv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# =============================================================================
# 2. SERVICE CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3011
SERVICE_NAME=notifications-service
DATABASE_SCHEMA=notifications_schema

# =============================================================================
# 3. SENDGRID CONFIGURATION (Email) 📧
# =============================================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@hospital.vn
SENDGRID_FROM_NAME=Bệnh viện Đa khoa

# =============================================================================
# 4. TWILIO CONFIGURATION (SMS) 📱
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+84xxxxxxxxx

# =============================================================================
# 5. RABBITMQ CONFIGURATION (Event Bus)
# =============================================================================
RABBITMQ_URL=amqp://admin:admin@localhost:5673
RABBITMQ_EXCHANGE=hospital.events

# =============================================================================
# 6. REDIS CONFIGURATION (Cache)
# =============================================================================
REDIS_URL=redis://localhost:6380
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# 7. REMINDER CRON JOB CONFIGURATION
# =============================================================================
REMINDER_CRON_ENABLED=true
REMINDER_CRON_EXPRESSION=*/5 * * * *
REMINDER_BATCH_SIZE=100

# =============================================================================
# 8. NOTIFICATION RETRIES
# =============================================================================
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=60000

# =============================================================================
# 9. LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# DEPRECATED/REMOVED CONFIGURATIONS
# =============================================================================
# FIREBASE - Out of MVP scope (Push notifications)
# NOTIFICATION_QUEUE_POLL_INTERVAL_MS - Replaced by cron job
# NOTIFICATION_QUEUE_BATCH_SIZE - Replaced by REMINDER_BATCH_SIZE

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
