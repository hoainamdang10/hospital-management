{
  "name": "appointments-service",
  "version": "1.0.0",
  "description": "Appointments Service - Hospital Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/main.ts",
    "clean": "rimraf dist .jest-cache coverage",
    "prebuild": "npm run clean",
    "build": "tsc && tsc-alias",
    "postbuild": "node scripts/copy-config.js",
    "start": "node dist/main.js",
    "pretest": "jest --clearCache",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src/test/unit",
    "test:integration": "jest --testPathPattern=src/test/integration --runInBand",
    "test:e2e": "jest --testPathPattern=e2e --runInBand",
    "test:all": "npm run test:unit && npm run test:integration",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "fix:verify-eventbus": "ts-node scripts/verify-event-bus.ts",
    "fix:backfill": "ts-node scripts/backfill-read-model.ts",
    "fix:test-sync": "ts-node scripts/test-read-model-sync.ts",
    "fix:all": "npm run fix:verify-eventbus && npm run fix:backfill && npm run fix:test-sync"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "@types/ioredis": "^4.28.10",
    "@types/swagger-ui-express": "^4.1.8",
    "amqplib": "^0.10.9",
    "axios": "^1.12.2",
    "axios-retry": "^4.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.8.1",
    "joi": "^17.9.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.2",
    "opossum": "^9.0.0",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "eslint": "^8.46.0",
    "jest": "^29.6.2",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.0.1",
    "rimraf": "^5.0.5",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.6"
  },
  "keywords": [
    "hospital-management",
    "healthcare",
    "microservice",
    "clean-architecture",
    "ddd",
    "cqrs",
    "event-driven"
  ]
}
