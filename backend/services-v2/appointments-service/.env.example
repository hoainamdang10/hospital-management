# Appointments Service Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
SUPABASE_URL=https://ciasxktujslgsdgylimv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3004
SERVICE_NAME=appointments-service

# =============================================================================
# EXTERNAL SERVICES (Optional - defaults provided)
# =============================================================================
# Patient Registry Service URL
PATIENT_SERVICE_URL=http://patient-registry-service:3002

# Provider Staff Service URL
PROVIDER_SERVICE_URL=http://provider-staff-service:3003

# Scheduler Service URL (for reminder scheduling)
# NOTE: Scheduler functionality merged into notifications-service (port 3011)
SCHEDULER_SERVICE_URL=http://notifications-service:3011
SCHEDULER_API_KEY=optional-scheduler-api-key-here

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins (whitelist for production)
# Leave blank to use defaults: http://localhost:3000,http://localhost:3101
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =============================================================================
# RABBITMQ CONFIGURATION (Event Bus)
# =============================================================================
# RabbitMQ connection URL
RABBITMQ_URL=amqp://admin:admin@rabbitmq-v2:5672

# RabbitMQ exchange name
RABBITMQ_EXCHANGE=hospital.events

# =============================================================================
# REDIS CONFIGURATION (Cache & Idempotency)
# =============================================================================
REDIS_URL=redis://redis-v2:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=appointments:

# =============================================================================
# CQRS READ MODEL CONFIGURATION
# =============================================================================
# Enable/disable read model sync (default: true)
ENABLE_READ_MODEL_SYNC=true

# Read model sync timeout in milliseconds (default: 5000)
READ_MODEL_SYNC_TIMEOUT=5000

# =============================================================================
# OUTBOX PATTERN CONFIGURATION
# =============================================================================
# Outbox polling interval in milliseconds (default: 5000)
OUTBOX_POLL_INTERVAL_MS=5000

# Outbox batch size (default: 50)
OUTBOX_BATCH_SIZE=50

# Outbox retry delays
OUTBOX_BASE_DELAY_MS=5000
OUTBOX_MAX_DELAY_MS=600000
OUTBOX_RESERVED_TIMEOUT_MINUTES=5

# =============================================================================
# TENANT CONFIGURATION
# =============================================================================
TENANT_ID=hospital-1

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_TRACKING=true

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
HEALTH_CHECK_TIMEOUT_MS=5000
ENABLE_DETAILED_HEALTH_CHECK=true
