,GAAG,CAAC,MAAM,KAAK,KAAK,IAAI,GAAG,CAAC,MAAM,KAAK,QAAQ,EAAE,CAAC;YACpD,OAAO,IAAI,EAAE,CAAC,CAAC,mCAAmC;QACpD,CAAC;QAED,MAAM,WAAW,GAAG,GAAG,CAAC,GAAG,CAAC,cAAc,CAAC,CAAC;QAC5C,IAAI,CAAC,WAAW,IAAI,CAAC,YAAY,CAAC,IAAI,CAAC,IAAI,CAAC,EAAE,CAAC,WAAW,CAAC,QAAQ,CAAC,IAAI,CAAC,CAAC,EAAE,CAAC;YAC3E,OAAO,GAAG,CAAC,MAAM,CAAC,GAAG,CAAC,CAAC,IAAI,CAAC;gBAC1B,OAAO,EAAE,KAAK;gBACd,OAAO,EAAE,iCAAiC;gBAC1C,SAAS,EAAE,wBAAwB;gBACnC,YAAY,EAAE,YAAY;gBAC1B,YAAY,EAAE,WAAW;gBACzB,SAAS,EAAE,IAAI,IAAI,EAAE,CAAC,WAAW,EAAE;gBACnC,IAAI,EAAE,GAAG,CAAC,IAAI;gBACd,MAAM,EAAE,GAAG,CAAC,MAAM;gBAClB,UAAU,EAAE,GAAG;aAChB,CAAC,CAAC;QACL,CAAC;QAED,IAAI,EAAE,CAAC;IACT,CAAC,CAAC;AACJ,CAAC",
      names: [],
      sources: ["D:\\hospital-management-V2\\backend\\services-v2\\scheduling-service\\src\\presentation\\middleware\\ValidationMiddleware.ts"],
      sourcesContent: ["/**\n * Validation Middleware - Presentation Layer\n * V2 Clean Architecture + DDD Implementation\n * Request validation middleware with Vietnamese healthcare rules\n * \n * @author Hospital Management Team\n * @version 2.0.0\n * @compliance Clean Architecture, Input Validation, Vietnamese Healthcare Standards\n */\n\nimport { Request, Response, NextFunction } from 'express';\nimport Joi from 'joi';\nimport { ValidationError } from './ErrorHandlingMiddleware';\n\n/**\n * Validation Middleware Factory\n */\nexport function validateRequest(schema: Joi.ObjectSchema, source: 'body' | 'query' | 'params' = 'body') {\n  return (req: Request, res: Response, next: NextFunction) => {\n    const dataToValidate = req[source];\n    \n    const { error, value } = schema.validate(dataToValidate, {\n      abortEarly: false,\n      allowUnknown: false,\n      stripUnknown: true,\n      context: {\n        maxDate: new Date(Date.now() + 60 * 24 * 60 * 60 * 1000) // 60 days from now\n      }\n    });\n\n    if (error) {\n      const validationErrors = error.details.map(detail => ({\n        field: detail.path.join('.'),\n        message: translateValidationMessage(detail.message, detail.type),\n        code: detail.type\n      }));\n\n      const validationError = new ValidationError(\n        'D\u1EEF li\u1EC7u \u0111\u1EA7u v\xE0o kh\xF4ng h\u1EE3p l\u1EC7',\n        validationErrors\n      );\n\n      return next(validationError);\n    }\n\n    // Replace the original data with validated and sanitized data\n    req[source] = value;\n    next();\n  };\n}\n\n/**\n * Translate Joi validation messages to Vietnamese\n */\nfunction translateValidationMessage(message: string, type: string): string {\n  const translations: { [key: string]: string } = {\n    // Required field errors\n    '\"{{#label}}\" is required': '{{#label}} l\xE0 b\u1EAFt bu\u1ED9c',\n    'any.required': 'Tr\u01B0\u1EDDng n\xE0y l\xE0 b\u1EAFt bu\u1ED9c',\n    \n    // String validation errors\n    'string.empty': 'Kh\xF4ng \u0111\u01B0\u1EE3c \u0111\u1EC3 tr\u1ED1ng',\n    'string.min': 'Ph\u1EA3i c\xF3 \xEDt nh\u1EA5t {{#limit}} k\xFD t\u1EF1',\n    'string.max': 'Kh\xF4ng \u0111\u01B0\u1EE3c v\u01B0\u1EE3t qu\xE1 {{#limit}} k\xFD t\u1EF1',\n    'string.length': 'Ph\u1EA3i c\xF3 \u0111\xFAng {{#limit}} k\xFD t\u1EF1',\n    'string.pattern.base': '\u0110\u1ECBnh d\u1EA1ng kh\xF4ng h\u1EE3p l\u1EC7',\n    'string.email': 'Email kh\xF4ng \u0111\xFAng \u0111\u1ECBnh d\u1EA1ng',\n    \n    // Number validation errors\n    'number.base': 'Ph\u1EA3i l\xE0 s\u1ED1',\n    'number.integer': 'Ph\u1EA3i l\xE0 s\u1ED1 nguy\xEAn',\n    'number.min': 'Ph\u1EA3i l\u1EDBn h\u01A1n ho\u1EB7c b\u1EB1ng {{#limit}}',\n    'number.max': 'Ph\u1EA3i nh\u1ECF h\u01A1n ho\u1EB7c b\u1EB1ng {{#limit}}',\n    'number.positive': 'Ph\u1EA3i l\xE0 s\u1ED1 d\u01B0\u01A1ng',\n    'number.negative': 'Ph\u1EA3i l\xE0 s\u1ED1 \xE2m',\n    \n    // Date validation errors\n    'date.base': 'Ph\u1EA3i l\xE0 ng\xE0y h\u1EE3p l\u1EC7',\n    'date.min': 'Ph\u1EA3i sau ng\xE0y {{#limit}}',\n    'date.max': 'Ph\u1EA3i tr\u01B0\u1EDBc ng\xE0y {{#limit}}',\n    'date.greater': 'Ph\u1EA3i sau {{#limit}}',\n    'date.less': 'Ph\u1EA3i tr\u01B0\u1EDBc {{#limit}}',\n    \n    // Array validation errors\n    'array.base': 'Ph\u1EA3i l\xE0 danh s\xE1ch',\n    'array.min': 'Ph\u1EA3i c\xF3 \xEDt nh\u1EA5t {{#limit}} ph\u1EA7n t\u1EED',\n    'array.max': 'Kh\xF4ng \u0111\u01B0\u1EE3c v\u01B0\u1EE3t qu\xE1 {{#limit}} ph\u1EA7n t\u1EED',\n    'array.length': 'Ph\u1EA3i c\xF3 \u0111\xFAng {{#limit}} ph\u1EA7n t\u1EED',\n    \n    // Object validation errors\n    'object.base': 'Ph\u1EA3i l\xE0 \u0111\u1ED1i t\u01B0\u1EE3ng h\u1EE3p l\u1EC7',\n    'object.unknown': 'Tr\u01B0\u1EDDng kh\xF4ng \u0111\u01B0\u1EE3c ph\xE9p',\n    \n    // Boolean validation errors\n    'boolean.base': 'Ph\u1EA3i l\xE0 true ho\u1EB7c false',\n    \n    // Any validation errors\n    'any.only': 'Ph\u1EA3i l\xE0 m\u1ED9t trong c\xE1c g