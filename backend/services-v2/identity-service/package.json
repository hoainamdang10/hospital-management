{
  "name": "identity-service",
  "version": "2.0.0",
  "description": "Identity & Access Service with enhanced resilience and monitoring",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/identity-service/src/main.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "test": "jest --coverage=false",
    "test:fast": "jest --coverage=false",
    "test:ci": "jest --coverage",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit --coverage=false",
    "test:integration": "jest tests/integration --coverage=false",
    "test:all": "jest --coverage=false",
    "test:watch": "jest --watch --coverage=false",
    "test:unit:coverage": "jest tests/unit --coverage",
    "test:integration:coverage": "jest tests/integration --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "health-check": "curl -f http://localhost:3001/health || exit 1",
    "docker:build": "docker build -t identity-service:latest .",
    "docker:run": "docker run -p 3001:3001 --env-file .env identity-service:latest",
    "db:seed": "ts-node scripts/seed-test-data.ts",
    "db:create-users": "ts-node scripts/create-test-users.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report playwright-report",
    "check:orphaned": "ts-node scripts/check-orphaned-pending-registrations.ts",
    "cleanup:pending-registrations": "ts-node scripts/cleanup-pending-registrations.ts",
    "cron:cleanup": "ts-node scripts/cron-cleanup-pending-registrations.ts"
  },
  "keywords": [
    "identity",
    "authentication",
    "authorization",
    "healthcare",
    "microservices",
    "clean-architecture",
    "ddd",
    "circuit-breaker",
    "resilience"
  ],
  "author": "Hospital Management Team",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@supabase/supabase-js": "^2.38.0",
    "@types/bcrypt": "^6.0.0",
    "amqplib": "^0.10.3",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ipaddr.js": "^2.2.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "prom-client": "^15.1.3",
    "redis": "^4.6.10",
    "resend": "^6.1.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/amqplib": "^0.10.1",
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.8.0",
    "@types/supertest": "^2.0.15",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.6",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "playwright": "^1.56.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hospital-management/identity-service.git"
  },
  "bugs": {
    "url": "https://github.com/hospital-management/identity-service/issues"
  },
  "homepage": "https://github.com/hospital-management/identity-service#readme"
}
