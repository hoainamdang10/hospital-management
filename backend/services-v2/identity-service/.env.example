# V2 Services Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=your_super_secure_jwt_secret_here_minimum_32_characters_for_production_use

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# For Docker: use redis-v2
# For local development: use localhost
REDIS_URL=redis://localhost:6380

# =============================================================================
# RABBITMQ CONFIGURATION
# =============================================================================
# For Docker: use rabbitmq-v2
# For local development: use localhost
RABBITMQ_URL=amqp://admin:admin@localhost:5673

# =============================================================================
# EMAIL CONFIGURATION (SendGrid)
# =============================================================================
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Hospital Management System
FRONTEND_URL=http://localhost:3000

# =============================================================================
# BILLING SERVICE - PAYOS CONFIGURATION
# =============================================================================
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# =============================================================================
# NOTIFICATIONS SERVICE CONFIGURATION
# =============================================================================
EMAIL_SERVICE_API_KEY=your_email_service_api_key
SMS_SERVICE_API_KEY=your_sms_service_api_key

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
NODE_ENV=development

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: debug, info, warn, error, fatal
# - debug: Detailed debugging information (development only)
# - info: General informational messages (default for production)
# - warn: Warning messages for potentially harmful situations
# - error: Error messages for failures
# - fatal: Critical errors that cause application termination
LOG_LEVEL=info

# =============================================================================
# MONITORING & METRICS CONFIGURATION
# =============================================================================
# Enable authentication for /metrics and /api-docs endpoints
# - true: Require token or IP whitelist for access (recommended for production)
# - false: Public access (development only)
METRICS_AUTH_ENABLED=false

# Token for accessing metrics endpoints (required if METRICS_AUTH_ENABLED=true)
# Generate a secure random token: openssl rand -hex 32
METRICS_AUTH_TOKEN=your_metrics_token_here

# Comma-separated list of allowed IPs for metrics access
# Default: localhost only (127.0.0.1, ::1, ::ffff:127.0.0.1)
# Example: METRICS_ALLOWED_IPS=127.0.0.1,10.0.0.1,192.168.1.100
# METRICS_ALLOWED_IPS=127.0.0.1

# =============================================================================
# INTERNAL SERVICE AUTHENTICATION
# =============================================================================
# Protects internal permission-check APIs. Enable in production.
INTERNAL_AUTH_ENABLED=true

# Comma-separated list of shared tokens (rotate frequently; store in secret manager)
# Example: INTERNAL_SERVICE_TOKENS=token1,token2
INTERNAL_SERVICE_TOKENS=

# Header inspected for internal token authentication (case-insensitive)
INTERNAL_AUTH_HEADER=X-Internal-Token

# Optional: Restrict internal endpoints to specific IPs or CIDR ranges
# Example: INTERNAL_ALLOWED_IPS=10.10.0.0/24,192.168.1.10
INTERNAL_ALLOWED_IPS=

# =============================================================================
# SWAGGER DOCUMENTATION
# =============================================================================
# Set to 'true' to enable Swagger UI in production (NOT RECOMMENDED)
# Set to 'false' to disable Swagger UI in production
ENABLE_SWAGGER=false
