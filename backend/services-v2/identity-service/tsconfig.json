{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false, // Disabled to allow underscore-prefixed unused properties during scope reduction
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@domain/*": ["src/domain/*"],
      "@application/*": ["src/application/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@presentation/*": ["src/presentation/*"],
      "@tests/*": ["tests/*"],
      "@shared/*": ["../shared/*"]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*",
    "../shared/domain/**/*",
    "../shared/application/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.simplified.ts",
    "../shared/examples/**/*",
    "../shared/testing/**/*",
    "../shared/workflows/**/*",
    "../shared/infrastructure/**/*",
    "../shared/domain/events/domain-events.ts",
    "../shared/domain/events/IDomainEventPublisher.ts",
    "../shared/domain/repositories/**/*"
  ]
}
