\n\n      // 7. Log audit trail\n      this.logger.info('Account locked successfully', {\n        userId: request.userId,\n        lockedBy: request.lockedBy,\n        reason: request.reason,\n        terminatedSessions: terminateSessions\n      });\n\n      return {\n        success: true,\n        message: `T\xE0i kho\u1EA3n \u0111\xE3 b\u1ECB kh\xF3a. L\xFD do: ${request.reason}`\n      };\n    } catch (error: any) {\n      this.logger.error('Failed to lock account', {\n        userId: request.userId,\n        lockedBy: request.lockedBy,\n        error: error.message\n      });\n\n      return {\n        success: false,\n        message: 'Kh\xF4ng th\u1EC3 kh\xF3a t\xE0i kho\u1EA3n. Vui l\xF2ng th\u1EED l\u1EA1i sau.',\n        error: 'LOCK_ACCOUNT_FAILED'\n      };\n    }\n  }\n\n  private validateRequest(request: LockAccountRequest): string | null {\n    if (!request.userId || request.userId.trim().length === 0) {\n      return 'User ID l\xE0 b\u1EAFt bu\u1ED9c';\n    }\n\n    if (!request.lockedBy || request.lockedBy.trim().length === 0) {\n      return 'Locked By (Admin ID) l\xE0 b\u1EAFt bu\u1ED9c';\n    }\n\n    if (!request.reason || request.reason.trim().length === 0) {\n      return 'L\xFD do kh\xF3a t\xE0i kho\u1EA3n l\xE0 b\u1EAFt bu\u1ED9c';\n    }\n\n    if (request.reason.length < 10) {\n      return 'L\xFD do kh\xF3a t\xE0i kho\u1EA3n ph\u1EA3i c\xF3 \xEDt nh\u1EA5t 10 k\xFD t\u1EF1';\n    }\n\n    return null;\n  }\n}\n\n"],
