equest.email.includes('@')) {\r\n        return {\r\n          success: false,\r\n          message: 'Email kh\xF4ng h\u1EE3p l\u1EC7',\r\n          error: 'INVALID_EMAIL'\r\n        };\r\n      }\r\n\r\n      if (!request.token || request.token.trim().length === 0) {\r\n        return {\r\n          success: false,\r\n          message: 'M\xE3 x\xE1c th\u1EF1c kh\xF4ng h\u1EE3p l\u1EC7',\r\n          error: 'INVALID_TOKEN'\r\n        };\r\n      }\r\n\r\n      // Use new interface method\r\n      await this.authService.verifyEmail(request.email, request.token);\r\n\r\n      this.logger.info('Email verified successfully via Supabase Auth', {\r\n        email: request.email\r\n      });\r\n\r\n      // Find user by email and update verification status\r\n      const email = Email.create(request.email);\r\n      const user = await this.userRepository.findByEmail(email);\r\n\r\n      if (!user) {\r\n        return {\r\n          success: false,\r\n          error: 'User not found',\r\n          message: 'Kh\xF4ng t\xECm th\u1EA5y ng\u01B0\u1EDDi d\xF9ng'\r\n        };\r\n      }\r\n\r\n      // Update user aggregate\r\n      user.verifyEmail();\r\n\r\n      // Persist using new repository signature\r\n      await this.userRepository.update(user);\r\n\r\n      this.logger.info('User profile updated with email verification', { userId: user.id });\r\n\r\n      return {\r\n        success: true,\r\n        userId: user.id,\r\n        message: 'Email \u0111\xE3 \u0111\u01B0\u1EE3c x\xE1c th\u1EF1c th\xE0nh c\xF4ng. B\u1EA1n c\xF3 th\u1EC3 \u0111\u0103ng nh\u1EADp ngay b\xE2y gi\u1EDD.'\r\n      };\r\n\r\n    } catch (error) {\r\n      this.logger.error('Email verification failed', { \r\n        email: request.email, \r\n        error: getErrorMessage(error) \r\n      });\r\n\r\n      return {\r\n        success: false,\r\n        message: `X\xE1c th\u1EF1c email th\u1EA5t b\u1EA1i: ${getErrorMessage(error)}`,\r\n        error: 'VERIFICATION_FAILED'\r\n      };\r\n    }\r\n 