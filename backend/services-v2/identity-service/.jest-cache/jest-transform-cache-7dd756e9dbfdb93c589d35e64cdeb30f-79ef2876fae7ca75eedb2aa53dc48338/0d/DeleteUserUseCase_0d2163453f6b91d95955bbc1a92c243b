y: 'CRITICAL'\n        });\n\n        return {\n          success: true,\n          message: 'Ng\u01B0\u1EDDi d\xF9ng \u0111\xE3 \u0111\u01B0\u1EE3c x\xF3a v\u0129nh vi\u1EC5n',\n          deletionType: 'hard'\n        };\n\n      } else {\n        // Soft delete - deactivate user\n        user.deactivate();\n        await this.userRepository.update(user);\n\n        // Log soft deletion for audit\n        this.logger.info('User deactivated', {\n          userId,\n          requesterId,\n          reason: reason || 'No reason provided',\n          userEmail: user.email.value,\n          timestamp: new Date().toISOString()\n        });\n\n        return {\n          success: true,\n          message: 'Ng\u01B0\u1EDDi d\xF9ng \u0111\xE3 \u0111\u01B0\u1EE3c v\xF4 hi\u1EC7u h\xF3a',\n          deletionType: 'soft'\n        };\n      }\n\n    } catch (error) {\n      this.logger.error('Failed to delete user', {\n        userId,\n        requesterId,\n        hardDelete,\n        error: getErrorMessage(error)\n      });\n\n      return {\n        success: false,\n        error: getErrorMessage(error),\n        message: 'L\u1ED7i khi x\xF3a ng\u01B0\u1EDDi d\xF9ng'\n      };\n    }\n  }\n}\n"],
