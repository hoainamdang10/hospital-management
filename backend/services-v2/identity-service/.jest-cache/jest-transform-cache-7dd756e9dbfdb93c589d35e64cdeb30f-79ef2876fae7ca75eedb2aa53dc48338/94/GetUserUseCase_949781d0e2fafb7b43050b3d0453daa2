atch (error) {\n      this.logger.error('Failed to get user', {\n        userId,\n        requesterId,\n        error: getErrorMessage(error)\n      });\n\n      return {\n        success: false,\n        error: getErrorMessage(error),\n        message: 'L\u1ED7i khi l\u1EA5y th\xF4ng tin ng\u01B0\u1EDDi d\xF9ng'\n      };\n    }\n  }\n}\n\n"],
