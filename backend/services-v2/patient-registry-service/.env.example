# Patient Registry Service - Environment Configuration Template
# Copy this file to .env and fill in your values
# For multi-env setup: use .env.local (dev) or .env.docker (Docker)

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3003

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_SCHEMA=patient_schema

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=your_jwt_secret

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Local: redis://localhost:6379
# Docker: redis://redis-v2:6379
REDIS_URL=redis://localhost:6379

# =============================================================================
# RABBITMQ CONFIGURATION
# =============================================================================
# Local: amqp://admin:admin@localhost:5672
# Docker: amqp://admin:admin@rabbitmq-v2:5672
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# =============================================================================
# INTER-SERVICE COMMUNICATION
# =============================================================================
# Local: http://localhost:PORT
# Docker: http://service-name:PORT
IDENTITY_SERVICE_URL=http://localhost:3001

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
