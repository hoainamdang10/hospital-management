# Scheduler Service Configuration

# Service
NODE_ENV=development
PORT=3030
COMPONENT=api  # api | materializer | worker | publisher

# Database (Supabase)
SUPABASE_URL=https://ciasxktujslgsdgylimv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# Message Bus (RabbitMQ)
RABBITMQ_URL=amqp://admin:admin@localhost:5673
RABBITMQ_EXCHANGE=hospital.events

# Cache (Redis)
REDIS_URL=redis://localhost:6380

# Authentication
JWT_SECRET=your_jwt_secret_for_service_auth
JWT_EXPIRY=300  # 5 minutes

# Worker Configuration
WORKER_ID=worker-1  # Optional: Unique worker identifier (auto-generated if not set)
WORKER_SEGMENT=0  # Optional: Segment number for horizontal scaling
WORKER_CONCURRENCY=10
WORKER_POLL_INTERVAL=5000  # 5 seconds
WORKER_LEASE_TTL=60000  # 1 minute
WORKER_GRACE_WINDOW_MS=60000  # 1 minute - Grace period for late runs

# Materializer Configuration
MATERIALIZATION_INTERVAL=60000  # 1 minute
MATERIALIZATION_LOOKAHEAD_HOURS=48

# Publisher Configuration
PUBLISH_BATCH_SIZE=100
PUBLISH_INTERVAL=1000  # 1 second

# CleanerWorker Configuration
CLEANER_INTERVAL=86400000  # 24 hours (in milliseconds)
CLEANER_RUNS_RETENTION_DAYS=30  # Delete completed runs older than 30 days
CLEANER_OUTBOX_RETENTION_DAYS=7  # Delete published outbox older than 7 days
CLEANER_DEAD_LETTERS_RETENTION_DAYS=90  # Delete dead letters older than 90 days

# Observability
METRICS_PORT=9090
LOG_LEVEL=info

# Multi-tenancy
DEFAULT_TENANT_ID=hospital-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100
