{
  "name": "scheduler-service",
  "version": "1.0.0",
  "description": "Scheduler Platform - Time-driven Infrastructure Service for Hospital Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:api": "NODE_ENV=production COMPONENT=api node dist/api.js",
    "start:materializer": "NODE_ENV=production COMPONENT=materializer node dist/materializer.js",
    "start:worker": "NODE_ENV=production COMPONENT=worker node dist/worker.js",
    "start:publisher": "NODE_ENV=production COMPONENT=publisher node dist/publisher.js",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "scheduler",
    "cron",
    "rrule",
    "microservices",
    "clean-architecture",
    "ddd",
    "transactional-outbox"
  ],
  "author": "Hospital Management Team",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "amqplib": "^0.10.3",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "prom-client": "^15.1.0",
    "rrule": "^2.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
