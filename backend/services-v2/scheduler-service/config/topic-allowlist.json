{
  "$schema": "./topic-allowlist.schema.json",
  "version": "1.0.0",
  "lastUpdated": "2025-10-21T10:00:00Z",
  "description": "Topic allowlist for Scheduler Service. Supports wildcards (*).",
  
  "allowlist": {
    "appointments": {
      "description": "Appointment scheduling and reminders",
      "topics": [
        "appointments.appointment.reminder.24h",
        "appointments.appointment.reminder.2h",
        "appointments.appointment.reminder.1h",
        "appointments.appointment.cancelled",
        "appointments.appointment.rescheduled",
        "appointments.appointment.confirmed",
        "appointments.queue.check",
        "appointments.queue.notify",
        "appointments.waitlist.process"
      ],
      "wildcards": [
        "appointments.appointment.reminder.*",
        "appointments.queue.*"
      ]
    },
    
    "billing": {
      "description": "Billing and payment processing",
      "topics": [
        "billing.invoice.generate.monthly",
        "billing.invoice.generate.weekly",
        "billing.invoice.send",
        "billing.payment.reminder",
        "billing.payment.overdue",
        "billing.payment.overdue.escalate",
        "billing.report.daily",
        "billing.report.monthly",
        "billing.reconciliation.daily"
      ],
      "wildcards": [
        "billing.invoice.generate.*",
        "billing.payment.*",
        "billing.report.*"
      ]
    },
    
    "notifications": {
      "description": "Multi-channel notifications",
      "topics": [
        "notifications.alert.send",
        "notifications.email.send",
        "notifications.sms.send",
        "notifications.push.send",
        "notifications.batch.process",
        "notifications.retry.failed"
      ],
      "wildcards": [
        "notifications.*"
      ]
    },
    
    "clinical": {
      "description": "Clinical and EMR operations",
      "topics": [
        "clinical.lab.result.check",
        "clinical.prescription.refill.reminder",
        "clinical.prescription.expiry.alert",
        "clinical.vitals.check",
        "clinical.report.generate.daily",
        "clinical.report.generate.weekly"
      ],
      "wildcards": [
        "clinical.prescription.*",
        "clinical.report.generate.*"
      ]
    },
    
    "patient-registry": {
      "description": "Patient registry operations",
      "topics": [
        "patient-registry.patient.followup.reminder",
        "patient-registry.patient.birthday.greeting",
        "patient-registry.patient.checkup.annual",
        "patient-registry.patient.vaccination.reminder",
        "patient-registry.report.demographics.monthly"
      ],
      "wildcards": [
        "patient-registry.patient.*",
        "patient-registry.report.*"
      ]
    }
  },
  
  "validation": {
    "rules": [
      {
        "rule": "topic_format",
        "description": "Topic must match format: {service}.{resource}.{action}",
        "regex": "^[a-z-]+\\.[a-z-]+\\.[a-z0-9.-]+$"
      },
      {
        "rule": "service_match",
        "description": "Topic must start with ownerService name"
      },
      {
        "rule": "allowlist_check",
        "description": "Topic must be in allowlist or match wildcard pattern"
      }
    ]
  },
  
  "examples": {
    "valid": [
      {
        "ownerService": "appointments",
        "topic": "appointments.appointment.reminder.24h",
        "reason": "Exact match in allowlist"
      },
      {
        "ownerService": "appointments",
        "topic": "appointments.appointment.reminder.custom",
        "reason": "Matches wildcard: appointments.appointment.reminder.*"
      },
      {
        "ownerService": "billing",
        "topic": "billing.invoice.generate.quarterly",
        "reason": "Matches wildcard: billing.invoice.generate.*"
      }
    ],
    "invalid": [
      {
        "ownerService": "appointments",
        "topic": "billing.invoice.send",
        "reason": "Topic does not start with ownerService"
      },
      {
        "ownerService": "appointments",
        "topic": "appointments.unknown.action",
        "reason": "Not in allowlist and no matching wildcard"
      },
      {
        "ownerService": "unknown-service",
        "topic": "unknown-service.test",
        "reason": "ownerService not in allowlist"
      }
    ]
  }
}

