### 9. Update Existing Schedule by dedupKey
POST {{baseUrl}}/schedules:createOrUpdateByDedup
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tenantId": "hospital-1",
  "ownerService": "appointments",
  "scheduleType": "ONCE",
  "startAtUtc": "2025-10-24T09:00:00Z",
  "topicOrCommand": "appointments.appointment.reminder.24h",
  "payloadJson": {
    "appointmentId": "appt-123",
    "updated": true,
    "newTime": "2025-10-24T09:00:00Z"
  },
  "dedupKey": "appt-123:reminder-24h"
}

###

### 10. Get Schedule by ID
# Replace {scheduleId} with actual schedule ID from create response
GET {{baseUrl}}/schedules/{scheduleId}
Authorization: Bearer {{token}}

###

### 11. Get Schedule Runs
# Replace {scheduleId} with actual schedule ID
GET {{baseUrl}}/schedules/{scheduleId}/runs?limit=10&offset=0
Authorization: Bearer {{token}}

###

### 12. Run Now
# Replace {scheduleId} with actual schedule ID
POST {{baseUrl}}/schedules/{scheduleId}:runNow
Authorization: Bearer {{token}}

###

### 13. Cancel Schedules by Owner Resource ID
POST {{baseUrl}}/schedules:cancelByOwner
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tenantId": "hospital-1",
  "ownerService": "appointments",
  "ownerResourceId": "appt-123",
  "reason": "Appointment cancelled by patient"
}

###

### 14. Cancel All Schedules for Owner Service
POST {{baseUrl}}/schedules:cancelByOwner
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tenantId": "hospital-1",
  "ownerService": "appointments",
  "reason": "Bulk cancellation for testing"
}

###

### 15. Billing Service - Create Monthly Invoice Schedule
POST {{baseUrl}}/schedules:createOrUpdateByDedup
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tenantId": "hospital-1",
  "ownerService": "billing",
  "scheduleType": "ONCE",
  "startAtUtc": "2025-11-01T00:00:00Z",
  "topicOrCommand": "billing.invoice.generate.monthly",
  "payloadJson": {
    "month": "2025-11",
    "reportType": "monthly"
  },
  "dedupKey": "billing:invoice-2025-11"
}

###

### 16. Notifications Service - Send Alert
POST {{baseUrl}}/schedules:createOrUpdateByDedup
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tenantId": "hospital-1",
  "ownerService": "notifications",
  "scheduleType": "ONCE",
  "startAtUtc": "2025-10-21T10:00:00Z",
  "topicOrCommand": "notifications.alert.send",
  "payloadJson": {
    "alertType": "system",
    "message": "System maintenance scheduled"
  },
  "dedupKey": "notifications:system-alert-2025-10-21"
}

