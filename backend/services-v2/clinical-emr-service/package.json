{
  "name": "clinical-emr-service",
  "version": "1.0.0",
  "description": "Clinical/EMR Service - Hospital Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:unit": "jest --coverage --testPathPattern=tests/unit",
    "test:coverage:integration": "jest --coverage --testPathPattern=tests/integration",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "migrate:outbox": "ts-node -r tsconfig-paths/register scripts/apply-outbox-migration-direct.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "amqplib": "^0.10.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.0.0",
    "inversify": "^6.0.1",
    "joi": "^17.9.2",
    "morgan": "^1.10.0",
    "redis": "^4.6.10",
    "reflect-metadata": "^0.2.2",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.1",
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.5.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "eslint": "^8.46.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.6"
  },
  "keywords": [
    "hospital-management",
    "healthcare",
    "microservice",
    "clean-architecture",
    "ddd",
    "cqrs",
    "event-driven"
  ]
}
