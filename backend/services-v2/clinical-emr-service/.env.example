# Clinical EMR Service - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3027
HOST=localhost

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Database Schema
DATABASE_SCHEMA=clinical_schema

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=your_super_secure_jwt_secret_here_minimum_32_characters_for_production_use

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3101

# =============================================================================
# REDIS CONFIGURATION (Caching)
# =============================================================================
# For Docker: use redis-v2
# For local development: use localhost
REDIS_URL=redis://localhost:6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTL (in seconds)
CACHE_TTL=3600

# =============================================================================
# RABBITMQ CONFIGURATION (Event Bus)
# =============================================================================
# For Docker: use rabbitmq-v2
# For local development: use localhost
RABBITMQ_URL=amqp://admin:admin@localhost:5673
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# Exchange and Queue Names
RABBITMQ_EXCHANGE=clinical-emr-events
RABBITMQ_QUEUE=clinical-emr-queue

# =============================================================================
# INTEGRATION EVENT CONSUMER
# =============================================================================
INTEGRATION_CONSUMER_ENABLED=true
INTEGRATION_QUEUE=clinical-emr-service.integration
INTEGRATION_PREFETCH=5
INTEGRATION_ROUTING_KEYS=patient.registered,patient.updated,provider.staff.created,provider.staff.updated,provider.staff.deactivated,appointment.completed,appointment.scheduled

# =============================================================================
# FHIR COMPLIANCE CONFIGURATION
# =============================================================================
# FHIR Version (default: 4.0.1)
FHIR_VERSION=4.0.1

# FHIR Base URL (for resource references)
FHIR_BASE_URL=https://your-fhir-server.com/fhir

# =============================================================================
# VIETNAMESE HEALTHCARE STANDARDS
# =============================================================================
# Mã bệnh viện (Hospital Code)
HOSPITAL_CODE=BV001

# Mã tỉnh/thành phố
PROVINCE_CODE=HN

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: debug, info, warn, error, fatal
LOG_LEVEL=info

# Log format: json, pretty
LOG_FORMAT=pretty

# =============================================================================
# MONITORING & METRICS CONFIGURATION
# =============================================================================
# Enable authentication for /metrics and /api-docs endpoints
METRICS_AUTH_ENABLED=false

# Token for accessing metrics endpoints
METRICS_AUTH_TOKEN=your_metrics_token_here

# Comma-separated list of allowed IPs for metrics access
METRICS_ALLOWED_IPS=127.0.0.1

# =============================================================================
# INTERNAL SERVICE AUTHENTICATION
# =============================================================================
# Protects internal APIs
INTERNAL_AUTH_ENABLED=true

# Shared tokens for internal service communication
INTERNAL_SERVICE_TOKENS=

# Header for internal token authentication
INTERNAL_AUTH_HEADER=X-Internal-Token

# Allowed IPs for internal endpoints
INTERNAL_ALLOWED_IPS=

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Rate limit: requests per window
RATE_LIMIT_MAX=100

# Rate limit window in milliseconds (15 minutes)
RATE_LIMIT_WINDOW=900000

# =============================================================================
# AUDIT LOGGING CONFIGURATION
# =============================================================================
# Enable HIPAA audit logging
AUDIT_ENABLED=true

# Audit log retention period (in days)
AUDIT_RETENTION_DAYS=2555

# =============================================================================
# MEDICAL RECORD CONFIGURATION
# =============================================================================
# Medical record ID prefix
MEDICAL_RECORD_PREFIX=MED

# Auto-archive threshold (in days)
AUTO_ARCHIVE_DAYS=1825

# =============================================================================
# INTEGRATION ENDPOINTS
# =============================================================================
# Identity Service
IDENTITY_SERVICE_URL=http://localhost:3021

# Patient Registry Service
PATIENT_SERVICE_URL=http://localhost:3023

# Provider/Staff Service
PROVIDER_SERVICE_URL=http://localhost:3022

# Appointments Service
APPOINTMENTS_SERVICE_URL=http://localhost:3024

# Billing Service
BILLING_SERVICE_URL=http://localhost:3029

# Notifications Service
NOTIFICATIONS_SERVICE_URL=http://localhost:3031

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
# Storage bucket for medical attachments
STORAGE_BUCKET=clinical-attachments

# Max file size (in bytes) - 10MB
MAX_FILE_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.dcm,.xml

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
# Health check interval (in seconds)
HEALTH_CHECK_INTERVAL=30

# Service dependencies to check
HEALTH_CHECK_DEPENDENCIES=supabase,redis,rabbitmq

# =============================================================================
# SWAGGER DOCUMENTATION
# =============================================================================
# Enable Swagger UI (disable in production)
ENABLE_SWAGGER=false

# Swagger endpoint
SWAGGER_PATH=/api-docs

# =============================================================================
# OUTBOX PATTERN CONFIGURATION
# =============================================================================
# Enable Outbox Publisher Worker
OUTBOX_WORKER_ENABLED=true

# Polling interval in milliseconds (how often to check for pending events)
OUTBOX_POLLING_INTERVAL=1000

# Batch size (how many events to publish in one batch)
OUTBOX_BATCH_SIZE=50

# Retry interval in milliseconds (how often to retry failed events)
OUTBOX_RETRY_INTERVAL=5000

# Cleanup interval in milliseconds (how often to cleanup old events)
OUTBOX_CLEANUP_INTERVAL=3600000

# Event retention in days (how long to keep published events)
OUTBOX_RETENTION_DAYS=30

# =============================================================================
# DEVELOPMENT/TESTING CONFIGURATION
# =============================================================================
# Enable debug mode
DEBUG=false

# Enable request logging
REQUEST_LOGGING=true

# Test database schema
TEST_DATABASE_SCHEMA=clinical_schema_test
