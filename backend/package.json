{
  "name": "hospital-management-v2",
  "version": "2.0.0",
  "description": "Hospital Management System V2 - Clean Architecture with Microservices",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:v2",
    "dev:v2": "cd services-v2 && docker compose up -d",
    "dev:infrastructure": "docker compose --profile infrastructure up -d",
    "dev:core": "docker compose --profile core up -d",
    "dev:full": "docker compose --profile full up -d",
    "dev:gateway": "cd services/api-gateway && npm run dev",
    "dev:graphql": "cd services/graphql-gateway && npm run dev",
    "dev:frontend": "cd ../frontend && npm run dev",
    
    "setup:tables": "node scripts/setup-microservices-tables.js",
    "setup:env": "node scripts/setup-environment.js",
    "setup:security": "node scripts/setup-security.js",
    "security:audit": "node scripts/security-audit.js",
    "security:check": "npm run security:audit",
    "security:fix-permissions": "node scripts/fix-file-permissions.js",
    "security:fix-keys": "node scripts/fix-hardcoded-keys.js",
    "security:test-gitignore": "node scripts/test-gitignore.js",
    
    "build": "npm run build:gateway && npm run build:graphql && npm run build:v2 && npm run build:frontend",
    "build:gateway": "cd services/api-gateway && npm run build",
    "build:graphql": "cd services/graphql-gateway && npm run build",
    "build:v2": "cd services-v2 && npm run build:all",
    "build:frontend": "cd ../frontend && npm run build",
    
    "start": "npm run start:v2",
    "start:v2": "cd services-v2 && docker compose up",
    "start:infrastructure": "docker compose --profile infrastructure up",
    "start:core": "docker compose --profile core up",
    "start:full": "docker compose --profile full up",
    
    "stop": "docker compose down",
    "stop:v2": "cd services-v2 && docker compose down",
    "restart": "npm run stop && npm run start",
    "restart:v2": "npm run stop:v2 && npm run start:v2",
    
    "test": "npm run test:v2",
    "test:v2": "cd services-v2 && npm run test:all",
    "test:gateway": "cd services/api-gateway && npm run test",
    "test:graphql": "cd services/graphql-gateway && npm run test",
    "test:integration": "node scripts/test-integration-v2.js",
    
    "lint": "npm run lint:gateway && npm run lint:graphql && npm run lint:v2",
    "lint:gateway": "cd services/api-gateway && npm run lint",
    "lint:graphql": "cd services/graphql-gateway && npm run lint",
    "lint:v2": "cd services-v2 && npm run lint:all",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    
    "health-check": "node scripts/health-check-v2.js",
    "status": "docker compose ps",
    "logs": "docker compose logs -f",
    "logs:gateway": "docker compose logs -f api-gateway",
    "logs:graphql": "docker compose logs -f graphql-gateway",
    
    "db:check": "node scripts/check-database-status.js",
    "db:setup": "node scripts/run-database-setup.js",
    "db:setup-foreign-keys": "echo 'Run add-foreign-keys.sql in Supabase SQL Editor'",
    "db:setup-rls": "echo 'Run setup-rls-policies.sql and setup-rls-policies-part2.sql in Supabase SQL Editor'",
    "db:setup-indexes": "echo 'Run add-performance-indexes.sql in Supabase SQL Editor'",
    "db:deploy-complete": "node scripts/deploy-complete-database.js",
    "db:verify-complete": "node scripts/verify-complete-database.js",
    "db:seed": "node scripts/seed-test-data.js",
    "db:verify": "node scripts/verify-test-data.js",
    "db:cleanup": "node scripts/cleanup-test-data.js",
    "db:verify-schema": "node scripts/verify-schema-for-seeding.js",
    "db:check-fk": "node scripts/check-foreign-key-constraints.js",
    "db:analyze": "node scripts/analyze-seed-data.js",
    "db:summary": "node scripts/data-summary.js",
    "db:check-departments": "node scripts/check-existing-departments.js",
    "db:fix-schema": "node scripts/quick-schema-fix.js",
    "db:create-reviews": "node scripts/create-doctor-reviews-table.js",
    "db:verify-simple": "node scripts/verify-schema-simple.js",
    "db:seed-direct": "node scripts/seed-test-data-direct.js",
    "db:analyze-patterns": "node scripts/analyze-database-patterns.js",
    "db:seed-improved": "node scripts/seed-test-data-improved.js",
    
    "cleanup:incomplete-users": "node scripts/cleanup-incomplete-users.js",
    "migrate:all": "cd services-v2 && npm run migrate:all",
    "migrate:up": "cd services-v2 && npm run migrate:up",
    "migrate:down": "cd services-v2 && npm run migrate:down"
  },
  "keywords": [
    "hospital",
    "management",
    "microservices",
    "clean-architecture",
    "ddd",
    "healthcare",
    "nodejs",
    "typescript",
    "supabase",
    "docker"
  ],
  "author": "Hospital Management Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
