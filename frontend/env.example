# =============================================================================
# API CONFIGURATION
# =============================================================================
# API Gateway (Primary entry point - use this for all API calls)
NEXT_PUBLIC_API_URL=http://localhost:3101
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3101

# =============================================================================
# DIRECT SERVICE URLS (For development/debugging only - NOT recommended for production)
# =============================================================================
# Core Services
NEXT_PUBLIC_IDENTITY_SERVICE_URL=http://localhost:3001
NEXT_PUBLIC_PATIENT_SERVICE_URL=http://localhost:3002
NEXT_PUBLIC_PROVIDER_SERVICE_URL=http://localhost:3003

# Business Services
NEXT_PUBLIC_APPOINTMENTS_SERVICE_URL=http://localhost:3004
NEXT_PUBLIC_BILLING_SERVICE_URL=http://localhost:3009

# Supporting Services
NEXT_PUBLIC_NOTIFICATIONS_SERVICE_URL=http://localhost:3011

# =============================================================================
# REMOVED SERVICES (For reference only - DO NOT USE)
# =============================================================================
# Clinical EMR Service - DISABLED FOR MVP
# NEXT_PUBLIC_CLINICAL_SERVICE_URL=http://localhost:3005

# Department Service - MERGED into Provider/Staff Service
# Access departments via NEXT_PUBLIC_PROVIDER_SERVICE_URL/api/v1/departments

# App Configuration
NEXT_PUBLIC_APP_NAME="Hospital Management System V2"
NEXT_PUBLIC_APP_VERSION="2.0.0"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEV_MODE=false

# Feature Flags
NEXT_PUBLIC_ENABLE_MFA=true
NEXT_PUBLIC_ENABLE_FHIR=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# PayOS Configuration (for billing)
NEXT_PUBLIC_PAYOS_CLIENT_ID=
NEXT_PUBLIC_PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Supabase (if using for file storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# AI CHATBOT CONFIGURATION
# =============================================================================
# Google Gemini API Key (Get free key at: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

