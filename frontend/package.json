{
  "name": "hospital-management-frontend",
  "version": "2.0.0",
  "private": true,
  "description": "Hospital Management System V2 - Frontend (Next.js 15 + React 18 + TypeScript)",
  "author": "Hospital Management Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "generate:types": "npm run generate:types:identity && npm run generate:types:patient && npm run generate:types:provider && npm run generate:types:appointments && npm run generate:types:clinical && npm run generate:types:billing && npm run generate:types:notifications",
    "generate:types:identity": "openapi-typescript http://localhost:3021/api-docs/json -o types/api/identity-service.ts",
    "generate:types:patient": "openapi-typescript http://localhost:3023/api-docs/json -o types/api/patient-service.ts",
    "generate:types:provider": "openapi-typescript http://localhost:3022/api-docs/json -o types/api/provider-service.ts",
    "generate:types:appointments": "openapi-typescript http://localhost:3024/api-docs/json -o types/api/appointments-service.ts",
    "generate:types:clinical": "openapi-typescript http://localhost:3027/api-docs/json -o types/api/clinical-service.ts",
    "generate:types:billing": "openapi-typescript http://localhost:3029/api-docs/json -o types/api/billing-service.ts",
    "generate:types:notifications": "openapi-typescript http://localhost:3031/api-docs/json -o types/api/notifications-service.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.5",
    "@supabase/supabase-js": "^2.80.0",
    "@tanstack/react-query": "^5.62.11",
    "@tanstack/react-query-devtools": "^5.62.11",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.468.0",
    "next": "^15.3.2",
    "next-themes": "^0.4.6",
    "numeral": "^2.0.6",
    "react": "^18.3.1",
    "react-big-calendar": "^1.15.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.66.0",
    "recharts": "^2.15.0",
    "sonner": "^1.7.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/numeral": "^2.0.5",
    "@types/react": "^18.3.18",
    "@types/react-big-calendar": "^1.8.12",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.11",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
